{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://nolt-admin-backend-production.up.railway.app/api/:path*"
        },
        {
            "source": "/auth/:path*",
            "destination": "https://nolt-admin-backend-production.up.railway.app/auth/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}