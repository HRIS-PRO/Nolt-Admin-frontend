{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "http://noltadmin1.eu-central-1.elasticbeanstalk.com/api/:path*"
        },
        {
            "source": "/auth/:path*",
            "destination": "http://noltadmin1.eu-central-1.elasticbeanstalk.com/auth/:path*"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "http://noltadmin1.eu-central-1.elasticbeanstalk.com/socket.io/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}